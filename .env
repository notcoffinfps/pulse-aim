THEME=https://raw.githubusercontent.com/aaaaalexis/obsidian-baseline/HEAD/theme.css
BASE_THEME=dark
dgHomeLink=true
SITE_NAME_HEADER=pulseAim
SITE_MAIN_LANGUAGE=en
SITE_BASE_URL=
SHOW_CREATED_TIMESTAMP=false
TIMESTAMP_FORMAT=MMM dd, yyyy h:mm a
SHOW_UPDATED_TIMESTAMP=false
NOTE_ICON_DEFAULT=
NOTE_ICON_TITLE=false
NOTE_ICON_FILETREE=false
NOTE_ICON_INTERNAL_LINKS=false
NOTE_ICON_BACK_LINKS=false
STYLE_SETTINGS_CSS=body.css-settings-manager { --heading-spacing: 2em; --h1-font: Oxanium; --h2-font: Oxanium; --h3-font: Oxanium; --h4-font: Oxanium; --h5-font: Oxanium; --h6-font: Oxanium; --radius-modifier: 0.5; --density-modifier: 0.75; } body.theme-light.css-settings-manager { --background-secondary: #313131; } body.theme-dark.css-settings-manager { --background-primary: #282828; --background-secondary: #1F1F1F; --background-secondary-alt: #FF5858; --background-modifier-hover: #FF4C4C; --interactive-normal: #515151; --text-selection: #FFFFFF80; }
STYLE_SETTINGS_BODY_CLASSES=mod-windows is-frameless is-hidden-frameless obsidian-app styled-scrollbars show-inline-title is-floating-nav auto-full-screen show-ribbon show-view-header css-settings-manager minimal-readable theme-dark is-focused accented-interface color-scheme-accent melange-light contrast-light default-dark contrast-dark layout-baseline input-baseline status-bar-baseline tab-default tab-stack-top view-header-title-hover tab-top-left-stacked tab-left-compact tab-top-right-icon tab-right-compact nav-action-dot nav-item-baseline colorful-folders-off active-line-off active-line-color-default table-normal bases-normal img-normal metadata-default metadata-add-property-always colorful-headings-off blockquote-baseline callouts-default code-default embed-side pdf-shadow table-width-full
USE_FULL_RESOLUTION_IMAGES=false
dgPassFrontmatter=false
dgShowBacklinks=false
dgShowLocalGraph=false
dgShowInlineTitle=true
dgShowFileTree=true
dgEnableSearch=true
dgShowToc=true
dgLinkPreview=false
dgShowTags=true